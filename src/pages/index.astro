---
import Base from "../layouts/Base.astro";
import GameCard from "../components/GameCard.astro";
import ToolCard from "../components/ToolCard.astro";
import { games, unityTools } from "../data/games";
import { projects } from "../data/projects";
import { getCollection } from "astro:content";

const recentPosts = (await getCollection("journal", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}

const links = [
  { label: "github", href: "https://github.com/plyr4" },
  { label: "itch.io", href: "https://plyr4.itch.io" },
  { label: "email", href: "mailto:davelvader@gmail.com" },
];

---

<Base title="dave vader">
  <div class="container">
    <section class="hero">
      <div class="hero-inner">
        <p class="name-title">dave vader</p>
        <p class="tagline">coding. making games.</p>
        <nav class="link-row">
          {
            links.map(({ label, href }) => (
              <a
                href={href}
                class="link-pill"
                target="_blank"
                rel="noopener noreferrer"
              >
                {label}
              </a>
            ))
          }
        </nav>
      </div>
    </section>

    <section class="section" id="about">
      <h2 class="section-title">about</h2>
      <p class="prose">
        i work at Target in engineering infrastructure. 
      </br>i studied CS at Michigan, and i make games in my free
        time.
      </p>
    </section>

    <section class="section" id="work">
      <h2 class="section-title">projects</h2>
      <ul class="game-grid">
        {
          projects.map(({ title, description, href }) => (
            <ToolCard
              title={title}
              description={description}
              href={href}
            />
          ))
        }
      </ul>
    </section>

    <section class="section" id="games">
      <h2 class="section-title">games</h2>
      <ul class="game-grid">
        {
          games.map((game) => (
            <GameCard
              title={game.title}
              description={game.description}
              bannerImg={game.bannerImg}
              demoHref={game.demoHref}
            />
          ))
        }
      </ul>
    </section>

    <section class="section" id="unity-tools">
      <h2 class="section-title">unity tools</h2>
      <ul class="game-grid">
        {
          unityTools.map((tool) => (
            <ToolCard
              title={tool.title}
              description={tool.description}
              href={tool.href}
            />
          ))
        }
      </ul>
    </section>

    <section class="section" id="journal">
      <h2 class="section-title">journal</h2>
      <ul class="post-list">
        {
          recentPosts.map((post) => (
            <li>
              <a href={`${import.meta.env.BASE_URL}journal/${post.id.replace(/\.[^.]+$/, '')}`} class="post-row">
                <span class="post-title">{post.data.title}</span>
                <span class="post-meta">
                  <span class="post-desc">{post.data.description}</span>
                  <span class="post-date">{formatDate(post.data.pubDate)}</span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
      <a href={`${import.meta.env.BASE_URL}journal`} class="see-all">all entries →</a>
    </section>

    <footer class="footer">
    </footer>
  </div>
</Base>

<style>
  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .post-row {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: inherit;
    transition: border-color var(--transition), background var(--transition);
  }

  .post-row:hover {
    opacity: 1;
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  .post-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text);
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .post-desc {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .see-all {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
  }

  .see-all:hover {
    color: var(--accent);
    opacity: 1;
  }
</style>
