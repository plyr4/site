---
import Base from "../layouts/Base.astro";
import GameCard from "../components/GameCard.astro";
import ToolCard from "../components/ToolCard.astro";
import "../styles/index.css";

const links = [
  { label: "github", href: "https://github.com/plyr4" },
  { label: "itch.io", href: "https://plyr4.itch.io" },
  { label: "email", href: "mailto:davelvader@gmail.com" },
];

const projects = [
  {
    title: "Vela",
    description: "Target's official CICD framework",
    href: "https://github.com/go-vela",
  },
  {
    title: "plyr4/pen-plotter",
    description: " A small program for generating pen plotter art",
    href: "https://github.com/plyr4/pen-plotter-art",
  },
    {
    title: "plyr4/go-ebiten-multiplayer",
    description: "small multiplayer framework made with Go, ebitengine and websockets",
    href: "https://github.com/plyr4/go-ebiten-multiplayer",
  },
  {
    title: "plyr4/ha-laundry",
    description: "Home Assistant integration for laundry machine status",
    href: "https://github.com/plyr4/ha-laundry",
  },
  {
    title: "plyr4/site",
    description: "this site, minimal personal page built with astro",
    href: "https://github.com/plyr4/site",
  },
];

const unityTools = [
  {
    title: "unity-build-factory",
    description: "re-usable CI/CD game builder workflows",
    href: "https://github.com/plyr4/unity-build-factory",
  },
    {
    title: "unity-state-machine",
    description: "directed acyclical state machine",
    href: "https://github.com/plyr4/unity-game-state-machine",
  },
  {
    title: "unity-input-system",
    description: "global input manager",
    href: "https://github.com/plyr4/unity-input-system",
  },
  {
    title: "unity-screen-transition",
    description: "drop-in screen transition system",
    href: "https://github.com/plyr4/unity-screen-transition",
  },
  {
    title: "unity-grid3d",
    description: "3D grid system",
    href: "https://github.com/plyr4/unity-grid3d",
  },
  {
    title: "unity-event-system",
    description: "drop-in event system",
    href: "https://github.com/plyr4/unity-event-system",
  }
];

const games = [
  {
    title: "Margarita Mayhem",
    description: "Keep the drinks flowing.",
    bannerImg: "/games/margarita-mayhem.png",
    demoHref: "https://plyr4.itch.io/margarita-mayhem",
  },
  {
    title: "Lovoflow",
    description: "Achieve tranquility.",
    bannerImg: "/games/lovoflow.gif",
    demoHref: "https://plyr4.itch.io/lovoflow",
  },
  {
    title: "Djimm's Revenge",
    description: "Escape the temple.",
    bannerImg: "/games/djimms-revenge.png",
    demoHref: "https://github.com/plyr4/djimms-revenge",
  },
  {
    title: "Mlord",
    description: "Protect the caravan.",
    bannerImg: "/games/mlord.png",
    demoHref: "https://plyr4.github.io/mlord",
  },
];
---

<Base title="dave vader">
  <div class="container">
    <section class="hero">
      <div class="hero-inner">
        <p class="name-title">dave vader</p>
        <p class="tagline">coding. making games.</p>
        <nav class="link-row">
          {
            links.map(({ label, href }) => (
              <a
                href={href}
                class="link-pill"
                target="_blank"
                rel="noopener noreferrer"
              >
                {label}
              </a>
            ))
          }
        </nav>
      </div>
    </section>

    <section class="section" id="about">
      <h2 class="section-title">about</h2>
      <p class="prose">
        I work at Target in engineering infrastructure. 
      </br>I studied CS at Michigan, and I make games in my free
        time.
      </p>
    </section>

    <section class="section" id="work">
      <h2 class="section-title">projects</h2>
      <ul class="card-list">
        {
          projects.map(({ title, description, href }) => (
            <li>
              <a
                href={href}
                class="card"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="card-title">{title}</span>
                <span class="card-desc">{description}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="section" id="games">
      <h2 class="section-title">games</h2>
      <ul class="game-grid">
        {
          games.map((game) => (
            <GameCard
              title={game.title}
              description={game.description}
              bannerImg={game.bannerImg}
              demoHref={game.demoHref}
            />
          ))
        }
      </ul>
    </section>

    <section class="section" id="unity-tools">
      <h2 class="section-title">unity tools</h2>
      <ul class="game-grid">
        {
          unityTools.map((tool) => (
            <ToolCard
              title={tool.title}
              description={tool.description}
              href={tool.href}
            />
          ))
        }
      </ul>
    </section>

    <footer class="footer">
      <!-- <span class="muted"
        >built with <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer">astro</a
        ></span
      > -->
    </footer>
  </div>
</Base>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const hero = document.querySelector(".hero-inner");
    if (hero) {
      hero.animate(
        [
          { opacity: 0, transform: "translateY(12px)" },
          { opacity: 1, transform: "translateY(0)" },
        ],
        { duration: 500, easing: "ease", fill: "forwards" },
      );
    }
  });
</script>
