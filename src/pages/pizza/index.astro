---
import Base from "../../layouts/Base.astro";
import PizzaMaker from "../../components/PizzaMaker.astro";
import PizzaGallery from "../../components/PizzaGallery.astro";
---

<Base title="pizza" description="internet pizza shop">
    <div class="container">
        <section class="hero">
            <div class="hero-inner">
                <p class="name-title">the pizza shop</p>
                <p class="tagline">
                    make a pie before you go
                </p>
            </div>
        </section>

        <section class="section">
            <PizzaMaker />
        </section>

        <section class="section gallery">
            <PizzaGallery />
        </section>
    </div>
</Base>
