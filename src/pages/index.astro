---
import Base from '../layouts/Base.astro';

const links = [
  { label: 'github', href: 'https://github.com/plyr4' },
  { label: 'email', href: 'mailto:hello@example.com' },
];

const work = [
  {
    title: 'site',
    description: 'this site — minimal personal page built with astro.',
    href: 'https://github.com/plyr4/site',
  },
];
---

<Base title="dave">
  <div class="container">

    <!-- ── Hero ──────────────────────────────────── -->
    <section class="hero">
      <div class="hero-inner">
        <span class="tag">he/him</span>
        <h1>dave</h1>
        <p class="tagline">software engineer. building things on the internet.</p>
        <nav class="link-row">
          {links.map(({ label, href }) => (
            <a href={href} class="link-pill" target="_blank" rel="noopener noreferrer">
              {label}
            </a>
          ))}
        </nav>
      </div>
    </section>

    <!-- ── About ─────────────────────────────────── -->
    <section class="section" id="about">
      <h2 class="section-title">about</h2>
      <p class="prose">
        i like building software, automating tedious things, and keeping interfaces clean and fast.
        when i'm not at a keyboard i'm probably outside.
      </p>
    </section>

    <!-- ── Work ──────────────────────────────────── -->
    <section class="section" id="work">
      <h2 class="section-title">work</h2>
      <ul class="card-list">
        {work.map(({ title, description, href }) => (
          <li>
            <a href={href} class="card" target="_blank" rel="noopener noreferrer">
              <span class="card-title">{title}</span>
              <span class="card-desc">{description}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- ── Footer ────────────────────────────────── -->
    <footer class="footer">
      <span class="muted">built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">astro</a></span>
    </footer>

  </div>
</Base>

<style>
  /* ── Layout ──────────────────────────────────── */
  .container {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Hero ────────────────────────────────────── */
  .hero {
    padding: 6rem 0 4rem;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tag {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--text);
  }

  .tagline {
    color: var(--muted);
    font-size: 1rem;
  }

  /* ── Link row ────────────────────────────────── */
  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .link-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--text);
    background: transparent;
    transition: border-color var(--transition), background var(--transition);
  }

  .link-pill:hover {
    opacity: 1;
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  /* ── Sections ────────────────────────────────── */
  .section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
  }

  .section-title {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  .prose {
    color: var(--muted);
    font-size: 0.95rem;
    max-width: 480px;
  }

  /* ── Cards ───────────────────────────────────── */
  .card-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: inherit;
    transition: border-color var(--transition), background var(--transition);
  }

  .card:hover {
    opacity: 1;
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  .card-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text);
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--muted);
  }

  /* ── Footer ──────────────────────────────────── */
  .footer {
    padding: 2.5rem 0 3rem;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
  }

  .muted {
    color: var(--muted);
  }
</style>

<script>
  // Subtle entrance animation
  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.querySelector('.hero-inner');
    if (hero) {
      hero.animate(
        [
          { opacity: 0, transform: 'translateY(12px)' },
          { opacity: 1, transform: 'translateY(0)' },
        ],
        { duration: 500, easing: 'ease', fill: 'forwards' },
      );
    }
  });
</script>
