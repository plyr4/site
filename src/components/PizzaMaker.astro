<div class="pizza-container">
    <canvas id="pizza-canvas"></canvas>
    <canvas id="ui-canvas"></canvas>
</div>

<style>
    .pizza-container {
        position: relative;
        width: 480px;
        height: 480px;
        border: 2px solid var(--border);
    }

    #pizza-canvas {
        display: block;
        width: 100%;
        height: 100%;
        image-rendering: pixelated;
    }

    #ui-canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        image-rendering: pixelated;
    }

    @media (max-width: 480px) {
        .pizza-container {
            width: 340px;
            height: 340px;
        }
    }
</style>

<script>
    import { runPizzaShop } from "../pizza/app";

    const canvas = document.getElementById("pizza-canvas") as HTMLCanvasElement;
    const uiCanvas = document.getElementById("ui-canvas") as HTMLCanvasElement;
    runPizzaShop(canvas, uiCanvas);
</script>
