<div class="pizza-container">
    <canvas id="pizza-canvas"></canvas>
</div>

<style>
    .pizza-container {
        width: 480px;
        height: 480px;
        border: 2px solid var(--border);
    }

    #pizza-canvas {
        display: block;
        width: 100%;
        height: 100%;
        image-rendering: pixelated;
    }
</style>

<script>
    import { runPizzaShop } from "../pages/pizza/app";

    const canvas = document.getElementById("pizza-canvas") as HTMLCanvasElement;
    runPizzaShop(canvas);
</script>
