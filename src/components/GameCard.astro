---
interface Props {
  title: string;
  description: string;
  bannerImg: string;
  demoHref: string;
}

const { title, description, bannerImg, demoHref } = Astro.props;
---

<li class="game-card">
  <a href={demoHref} target="_blank" rel="noopener noreferrer">
    <div class="game-banner">
      <img src={`${import.meta.env.BASE_URL}${bannerImg.replace(/^\//, '')}`} alt={`${title} banner`} />
    </div>
    <div class="game-info">
      <span class="game-title">{title}</span>
      <span class="game-desc">{description}</span>
    </div>
  </a>
</li>

<style>
  .game-card a {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    overflow: hidden;
    color: inherit;
    transition: border-color var(--transition), background var(--transition);
  }

  .game-card a:hover {
    opacity: 1;
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  .game-banner {
    width: 100%;
    aspect-ratio: 16 / 7;
    overflow: hidden;
    background: var(--border);
  }

  .game-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition);
  }

  .game-card a:hover .game-banner img {
    transform: scale(1.02);
  }

  .game-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.6rem 0.75rem;
  }

  .game-title {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text);
  }

  .game-desc {
    font-size: 0.75rem;
    color: var(--muted);
  }
</style>
