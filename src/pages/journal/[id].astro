---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = (
    await getCollection("journal", ({ data }) => !data.draft)
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return posts.map((post, i) => ({
    params: { id: post.id.replace(/\.[^.]+$/, "") },
    props: {
      post,
      prev:
        i > 0
          ? {
              id: posts[i - 1].id.replace(/\.[^.]+$/, ""),
              title: posts[i - 1].data.title,
            }
          : null,
      next:
        i < posts.length - 1
          ? {
              id: posts[i + 1].id.replace(/\.[^.]+$/, ""),
              title: posts[i + 1].data.title,
            }
          : null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Base title={post.data.title} description={post.data.description}>
  <div class="container">
    <section class="hero">
      <div class="hero-inner">
        <a
          href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/journal`}
          class="back-link">← journal</a
        >
        <p class="name-title">{post.data.title}</p>
        <p class="tagline">{formatDate(post.data.pubDate)}</p>
      </div>
    </section>

    <section class="section">
      <article class="prose-content">
        <Content />
      </article>
    </section>

    <nav class="item-nav">
      {
        prev ? (
          <a href={`${base}/journal/${prev.id}`} class="nav-btn">
            ← {prev.title}
          </a>
        ) : (
          <span class="nav-btn nav-btn--disabled">←</span>
        )
      }
      {
        next ? (
          <a href={`${base}/journal/${next.id}`} class="nav-btn">
            {next.title} →
          </a>
        ) : (
          <span class="nav-btn nav-btn--disabled">→</span>
        )
      }
    </nav>
  </div>
</Base>

<style>
  .back-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
    display: inline-block;
  }

  .back-link:hover {
    color: var(--accent);
    opacity: 1;
  }

  .prose-content {
    color: var(--muted);
    font-size: 0.95rem;
    max-width: 480px;
    line-height: 1.8;
  }

  .prose-content :global(h1),
  .prose-content :global(h2),
  .prose-content :global(h3) {
    color: var(--text);
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .prose-content :global(h2) {
    font-size: 1rem;
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  .prose-content :global(p) {
    margin-bottom: 1rem;
  }

  .prose-content :global(a) {
    color: var(--accent);
  }

  .prose-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius);
    margin: 1rem 0;
    display: block;
  }

  .prose-content :global(p:has(img + img)) {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .prose-content :global(p:has(img + img) img) {
    flex: 1;
    min-width: 0;
    margin: 0;
    width: 100%;
  }

  .prose-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1em 0.35em;
  }

  .prose-content :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .prose-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose-content :global(blockquote) {
    border-left: 2px solid var(--border);
    padding-left: 1rem;
    color: var(--muted);
    font-style: italic;
    margin-bottom: 1rem;
  }

  .item-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
  }

  .nav-btn {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    transition: color var(--transition);
  }

  .nav-btn:hover {
    color: var(--accent);
    opacity: 1;
  }

  .nav-btn--disabled {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }
</style>
