---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const games = (
        await getCollection("games", ({ data }) => !data.draft)
    ).sort((a, b) => a.data.order - b.data.order);
    return games.map((game, i) => ({
        params: { id: game.id.replace(/\.[^.]+$/, "") },
        props: {
            game,
            prev:
                i > 0
                    ? {
                          id: games[i - 1].id.replace(/\.[^.]+$/, ""),
                          title: games[i - 1].data.title,
                      }
                    : null,
            next:
                i < games.length - 1
                    ? {
                          id: games[i + 1].id.replace(/\.[^.]+$/, ""),
                          title: games[i + 1].data.title,
                      }
                    : null,
        },
    }));
}

const { game, prev, next } = Astro.props;
const { Content } = await render(game);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const actions = [
    { label: "trailer", href: game.data.trailerLink },
    { label: "play", href: game.data.demoLink },
    { label: "github", href: game.data.githubLink },
];
---

<Base
    title={game.data.title}
    description={game.data.description ?? game.data.tagline}
>
    <div class="container">
        <section class="hero">
            <div class="hero-inner">
                <a href={`${base}/games`} class="back-link">← games</a>
                <p class="name-title">{game.data.title}</p>
                <p class="tagline">{game.data.tagline}</p>
            </div>
        </section>

        <section class="section">
            <div class="game-banner">
                {
                    game.data.bannerGif ? (
                        <img
                            src={game.data.bannerGif}
                            alt={`${game.data.title} banner`}
                            loading="eager"
                        />
                    ) : (
                        game.data.bannerImg && (
                            <Image
                                src={game.data.bannerImg}
                                alt={`${game.data.title} banner`}
                                loading="eager"
                            />
                        )
                    )
                }
            </div>

            <div class="game-actions">
                {
                    actions.map(({ label, href }) =>
                        href ? (
                            <a
                                href={href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="action-btn"
                            >
                                {label} →
                            </a>
                        ) : (
                            <span class="action-btn action-btn--disabled">
                                {label}
                            </span>
                        ),
                    )
                }
            </div>

            <article class="prose-content">
                <Content />
            </article>
        </section>

        <nav class="item-nav">
            {
                prev ? (
                    <a href={`${base}/games/${prev.id}`} class="nav-btn">
                        ← {prev.title}
                    </a>
                ) : (
                    <span class="nav-btn nav-btn--disabled">←</span>
                )
            }
            {
                next ? (
                    <a href={`${base}/games/${next.id}`} class="nav-btn">
                        {next.title} →
                    </a>
                ) : (
                    <span class="nav-btn nav-btn--disabled">→</span>
                )
            }
        </nav>

        <footer class="footer"></footer>
    </div>
</Base>

<style>
    .back-link {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--muted);
        margin-bottom: 0.5rem;
        display: inline-block;
    }

    .back-link:hover {
        color: var(--accent);
        opacity: 1;
    }

    .game-banner {
        width: 100%;
        aspect-ratio: 16 / 7;
        overflow: hidden;
        background: var(--border);
        border-radius: var(--radius);
        margin-bottom: 1.5rem;
    }

    .game-banner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .game-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 2rem;
    }

    .action-btn {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--accent);
        border: 1px solid var(--accent);
        border-radius: var(--radius);
        padding: 0.5rem 1.25rem;
        transition:
            background var(--transition),
            color var(--transition);
    }

    .action-btn:hover {
        background: var(--accent);
        color: var(--bg);
        opacity: 1;
    }

    .action-btn--disabled {
        color: var(--muted);
        border-color: var(--border);
        opacity: 0.5;
        cursor: default;
        pointer-events: none;
    }

    .prose-content {
        color: var(--muted);
        font-size: 0.95rem;
        max-width: 480px;
        line-height: 1.8;
    }

    .prose-content :global(h1),
    .prose-content :global(h2),
    .prose-content :global(h3) {
        color: var(--text);
        font-weight: 600;
        margin-top: 2rem;
        margin-bottom: 0.5rem;
    }

    .prose-content :global(h2) {
        font-size: 1rem;
        font-family: var(--font-mono);
        letter-spacing: 0.05em;
    }

    .prose-content :global(p) {
        margin-bottom: 1rem;
    }

    .prose-content :global(a) {
        color: var(--accent);
    }

    .prose-content :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: var(--radius);
        margin: 1rem 0;
        display: block;
    }

    .prose-content :global(p:has(img + img)) {
        display: flex;
        gap: 0.5rem;
        align-items: flex-start;
    }

    .prose-content :global(p:has(img + img) img) {
        flex: 1;
        min-width: 0;
        margin: 0;
        width: 100%;
    }

    .prose-content :global(code) {
        font-family: var(--font-mono);
        font-size: 0.85em;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 0.1em 0.35em;
    }

    .prose-content :global(pre) {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem 1.25rem;
        overflow-x: auto;
        margin-bottom: 1rem;
    }

    .prose-content :global(pre code) {
        background: none;
        border: none;
        padding: 0;
    }

    .prose-content :global(ul),
    .prose-content :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1rem;
    }

    .prose-content :global(blockquote) {
        border-left: 2px solid var(--border);
        padding-left: 1rem;
        color: var(--muted);
        font-style: italic;
        margin-bottom: 1rem;
    }

    .item-nav {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.5rem 0;
        border-top: 1px solid var(--border);
    }

    .nav-btn {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--muted);
        transition: color var(--transition);
    }

    .nav-btn:hover {
        color: var(--accent);
        opacity: 1;
    }

    .nav-btn--disabled {
        opacity: 0.3;
        cursor: default;
        pointer-events: none;
    }
</style>
