---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("journal", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { id: post.id.replace(/\.[^.]+$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Base title={`${post.data.title} — dave vader`} description={post.data.description}>
  <div class="container">
    <section class="hero">
      <div class="hero-inner">
        <a href="/journal" class="back-link">← journal</a>
        <p class="name-title">{post.data.title}</p>
        <p class="tagline">{formatDate(post.data.pubDate)}</p>
      </div>
    </section>

    <section class="section">
      <article class="prose-content">
        <Content />
      </article>
    </section>
  </div>
</Base>

<style>
  .back-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
    display: inline-block;
  }

  .back-link:hover {
    color: var(--accent);
    opacity: 1;
  }

  .prose-content {
    color: var(--muted);
    font-size: 0.95rem;
    max-width: 480px;
    line-height: 1.8;
  }

  .prose-content :global(h1),
  .prose-content :global(h2),
  .prose-content :global(h3) {
    color: var(--text);
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .prose-content :global(h2) {
    font-size: 1rem;
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  .prose-content :global(p) {
    margin-bottom: 1rem;
  }

  .prose-content :global(a) {
    color: var(--accent);
  }

  .prose-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1em 0.35em;
  }

  .prose-content :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .prose-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose-content :global(blockquote) {
    border-left: 2px solid var(--border);
    padding-left: 1rem;
    color: var(--muted);
    font-style: italic;
    margin-bottom: 1rem;
  }
</style>
