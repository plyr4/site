---
import Base from "../../layouts/Base.astro";
---

<Base title="pizza" description="internet pizza shop">
    <div class="container">
        <section class="hero">
            <div class="hero-inner">
                <p class="name-title">the pizza shop</p>
                <p class="tagline">make a pie before you go</p>
            </div>
        </section>
        <section class="section">
            <div class="pizza-container">
                <canvas id="pizza-canvas"></canvas>
            </div>
        </section>
    </div>
</Base>

<style>
    .pizza-container {
        width: 480px;
        height: 480px;
        border: 2px solid var(--border);
    }

    #pizza-canvas {
        display: block;
        width: 100%;
        height: 100%;
        image-rendering: pixelated;
    }
</style>

<script>
    import { runPizzaShop } from "./pizza";

    const canvas = document.getElementById("pizza-canvas") as HTMLCanvasElement;
    runPizzaShop(canvas);
</script>
