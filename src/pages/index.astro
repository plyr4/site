---
import Base from "../layouts/Base.astro";
import GameCard from "../components/GameCard.astro";
import ToolCard from "../components/ToolCard.astro";
import PizzaOfTheDay from "../components/PizzaOfTheDay.astro";
import { unityTools } from "../content/tools/tools";
import { projects } from "../content/projects/projects";
import { getCollection } from "astro:content";

const games = (await getCollection("games", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);

const recentPosts = (await getCollection("journal", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<Base>
  <div class="container">
    <section class="hero">
      <div class="hero-inner">
        <p class="name-title">
          dave vader <span class="subtitle">(@plyr4)</span>
        </p>
      </div>
    </section>

    <section class="section" id="about">
      <p class="prose">
        my name is dave
        <br />i live in minneapolis, working for Target in engineering
        infrastructure
        <br />i studied CS at Michigan, and i make games in my free time
        <br />
      </p>
    </section>

    <section class="section">
      <PizzaOfTheDay title="today's pie of the day" />
      <br />
      <p class="tagline">
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/pizza`}
          >make a pizza</a
        > before you go!
      </p>
    </section>

    <section class="section" id="work">
      <h2 class="section-title">projects</h2>
      <ul class="game-grid">
        {
          projects.map(({ title, description, href }) => (
            <ToolCard title={title} description={description} href={href} />
          ))
        }
      </ul>
    </section>

    <section class="section" id="games">
      <h2 class="section-title">games</h2>
      <ul class="game-grid">
        {
          games.map((game) => (
            <GameCard
              id={game.id.replace(/\.[^.]+$/, "")}
              title={game.data.title}
              tagline={game.data.tagline}
              bannerImg={game.data.bannerImg}
              bannerGif={game.data.bannerGif}
            />
          ))
        }
      </ul>
    </section>

    <section class="section" id="unity-tools">
      <h2 class="section-title">unity tools</h2>
      <ul class="game-grid">
        {
          unityTools.map((tool) => (
            <ToolCard
              title={tool.title}
              description={tool.description}
              href={tool.href}
            />
          ))
        }
      </ul>
    </section>

    <section class="section" id="journal">
      <h2 class="section-title">journal</h2>
      <ul class="post-list">
        {
          recentPosts.map((post) => (
            <li>
              <a
                href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/journal/${post.id.replace(/\.[^.]+$/, "")}`}
                class="post-row"
              >
                <span class="post-title">{post.data.title}</span>
                <span class="post-meta">
                  <span class="post-desc">{post.data.description}</span>
                  <span class="post-date">{formatDate(post.data.pubDate)}</span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
      <a
        href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/journal`}
        class="see-all">all entries →</a
      >
    </section>

    <footer class="footer"></footer>
  </div>
</Base>

<style>
  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .post-row {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: inherit;
    transition:
      border-color var(--transition),
      background var(--transition);
  }

  .post-row:hover {
    opacity: 1;
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  .post-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text);
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .post-desc {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .see-all {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
  }

  .see-all:hover {
    color: var(--accent);
    opacity: 1;
  }
</style>
