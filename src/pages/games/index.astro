---
import Base from "../../layouts/Base.astro";
import GameCard from "../../components/GameCard.astro";
import ToolCard from "../../components/ToolCard.astro";
import { getCollection } from "astro:content";
import { unityTools } from "../../content/tools/tools";

const games = (await getCollection("games", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base title="games">
  <div class="container">
    <section class="hero">
      <div class="hero-inner">
        <p class="name-title">games <span class="subtitle">(and tools)</span></p>
      </div>
    </section>

    <section class="section" id="games">
      <ul class="game-grid">
        {
          games.map((game) => (
            <GameCard
              id={game.id.replace(/\.[^.]+$/, "")}
              title={game.data.title}
              tagline={game.data.tagline}
              bannerImg={game.data.bannerImg}
              bannerGif={game.data.bannerGif}
            />
          ))
        }
      </ul>
    </section>

    <section class="section" id="unity-tools">
      <h2 class="section-title">unity tools</h2>
      <ul class="game-grid">
        {
          unityTools.map((tool) => (
            <ToolCard
              title={tool.title}
              description={tool.description}
              href={tool.href}
            />
          ))
        }
      </ul>
    </section>

    <footer class="footer"></footer>
  </div>
</Base>
